# ─── SERVIDOR ──────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MONGODB ATLAS ─────────────────────────────
MONGODB_URI=mongodb+srv://<usuario>:<contraseña>@cluster0.xxxxx.mongodb.net/serviya?retryWrites=true&w=majority

# ─── FIREBASE ADMIN SDK ─────────────────────────
# Descargá el JSON desde: Firebase Console → Configuración → Cuentas de servicio → Generar nueva clave privada
FIREBASE_PROJECT_ID=tu-proyecto-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com

# ─── MERCADO PAGO ───────────────────────────────
# Conseguilo en: https://www.mercadopago.com.ar/developers → Credenciales
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxx
MP_PUBLIC_KEY=TEST-xxxxxxxxxxxx
MP_WEBHOOK_SECRET=tu_webhook_secret

# ─── SEGURIDAD ──────────────────────────────────
JWT_SECRET=cambia_esto_por_algo_muy_secreto_y_largo_123456

# ─── FRONTEND URL (CORS) ─────────────────────────
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
